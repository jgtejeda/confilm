# Copiar a .env y ajustar los valores

# App
CI_ENVIRONMENT = development
app.baseURL = 'http://localhost/comisionfilm/'
app.secretKey = 'GENERAR_CON_php_-r_echo_bin2hex(random_bytes(32));'

# Base de datos (CI4)
database.default.hostname = db
database.default.database = registro_comision_film
database.default.username = rcf_user
database.default.password = cambia_esto
database.default.DBDriver = MySQLi
database.default.port = 3306

# Docker MySQL (para referencia)
DB_ROOT_PASSWORD = cambia_esto
DB_DATABASE = registro_comision_film
DB_USERNAME = rcf_user
DB_PASSWORD = cambia_esto

# Gmail SMTP
GMAIL_USER = notificaciones@comisionfilm.gob.mx
GMAIL_APP_PASSWORD = "xxxx xxxx xxxx xxxx"

# AWS S3
AWS_ACCESS_KEY_ID = AKIA_PLACEHOLDER
AWS_SECRET_ACCESS_KEY = placeholder_secret
AWS_REGION = us-east-1
AWS_S3_BUCKET = registro-comision-film

# Sesiones
session.driver = 'CodeIgniter\Session\Handlers\DatabaseHandler'
session.savePath = ci_sessions
session.expiration = 7200
session.cookieSecure = false
session.cookieSameSite = Strict

# Archivos
upload.maxSizeMB = 20
